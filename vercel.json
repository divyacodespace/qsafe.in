{
  "functions": {
    "api/index.py": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.py" }
  ],
  "env": {
    "VERCEL": "1",
    "PKI_NO_SCHEDULER": "1"
  },
  "crons": [
    {
      "path": "/api/status",
      "schedule": "0 */6 * * *"
    }
  ]
}
